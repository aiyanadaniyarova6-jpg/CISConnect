@* Hibiscus SVG partial - use variant="filled"|"stroke", size class via class attr *@
@{
    var variant = ViewData["HibiscusVariant"] as string ?? "filled";
    var animated = (ViewData["HibiscusAnimated"] as bool?) ?? false;
    bool stroke = variant == "stroke";
    string fillColor = stroke ? "none" : "url(#petalGrad)";
    string strokeColor = "#c2410c";
    double strokeW = stroke ? 2 : 1;
    double strokeOp = stroke ? 1 : 0.4;
    string animClass = animated ? "hibiscus-svg hib-animate" : "hibiscus-svg";
}

<svg viewBox="-160 -160 320 320" class="@animClass" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <defs>
        <radialGradient id="petalGrad" cx="50%" cy="40%">
            <stop offset="0%"   stop-color="#c2410c" stop-opacity="0.95" />
            <stop offset="60%"  stop-color="#c2410c" stop-opacity="1" />
            <stop offset="100%" stop-color="#7a2208" stop-opacity="0.9" />
        </radialGradient>
        <radialGradient id="centerGrad" cx="50%" cy="50%">
            <stop offset="0%"   stop-color="#fff8d4" />
            <stop offset="60%"  stop-color="#b8841f" />
            <stop offset="100%" stop-color="#7a4a0a" />
        </radialGradient>
    </defs>

    @* Leaves *@
    <g opacity="0.85">
        <ellipse cx="-110" cy="60" rx="48" ry="18" fill="#15803d" opacity="0.55" transform="rotate(-30 -110 60)" />
        <ellipse cx="115"  cy="70" rx="50" ry="20" fill="#15803d" opacity="0.55" transform="rotate(28 115 70)" />
    </g>

    @* Petals (5 × 72°) *@
    <g class="petals">
        @for (int i = 0; i < 5; i++) {
            int rot = i * 72;
            <g transform="rotate(@rot) translate(0 -10)" class="petal" style="--i:@i">
                <path d="M 0 0 C -36 -28 -44 -78 -22 -118 C -10 -140 10 -140 22 -118 C 44 -78 36 -28 0 0 Z"
                      fill="@fillColor"
                      stroke="@strokeColor"
                      stroke-width="@(strokeW)"
                      stroke-opacity="@(strokeOp)" />
                <path d="M 0 -10 C -2 -50 -2 -90 0 -130"
                      fill="none"
                      stroke="@(stroke ? "#c2410c" : "#fde0c4")"
                      stroke-opacity="@(stroke ? 0.6 : 0.5)"
                      stroke-width="1.5" />
            </g>
        }
    </g>

    @* Center stamen *@
    <g>
        <circle cx="0" cy="0" r="14"
                fill="@(stroke ? "none" : "url(#centerGrad)")"
                stroke="@(stroke ? "#c2410c" : "none")"
                stroke-width="2" />
        @if (!stroke) {
            @for (int i = 0; i < 6; i++) {
                double angle = i * 60 * Math.PI / 180;
                double sx = Math.Cos(angle) * 26;
                double sy = Math.Sin(angle) * 26;
                <circle cx="@sx.ToString("F1")" cy="@sy.ToString("F1")" r="2.5" fill="#fff8d4" opacity="0.9" />
            }
        }
    </g>
</svg>
